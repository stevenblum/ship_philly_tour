VITE_APP_BASE_PATH=/
VITE_SCENE_MODE=lightweight
VITE_ENABLE_GOOGLE_PHOTOREALISTIC=false
# Cesium ion Allowed URLs must include localhost/127.0.0.1 dev URLs and the GitHub Pages URL; All URLs works only as a less-restrictive troubleshooting setting.
VITE_CESIUM_ION_TOKEN=
VITE_ENABLE_FLOW_CHEVRONS=true
VITE_ENABLE_AUTHORING=true
VITE_LOG_LEVEL=info
